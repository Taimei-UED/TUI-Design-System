{
  "name": "@wiz/idm-ui",
  "version": "0.1.0",
  "description": "Wiz iDM Design System — React component library (tokens, components, light/dark theming).",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "files": ["dist", "styles"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./styles/styles.css",
    "./tokens/*": "./styles/tokens/*"
  },
  "scripts": {
    "build": "tsup && npm run build:css",
    "build:css": "node ./scripts/copy-css.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0"
  }
}
