        "selector": "JSXOpeningElement[name.name='Search'] > JSXAttribute > JSXIdentifier[name!=/^(?:width|disabled|onChange|onSearch|key|ref|className|style|children)$/]",
        "message": "<Search> doesn't accept that prop. Declared props: width, disabled, onChange, onSearch."
